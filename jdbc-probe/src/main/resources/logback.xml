<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- This is the key logger — shows #chunks #threads #slots -> pool -->
    <logger name="net.snowflake.client.internal.jdbc.SnowflakeChunkDownloader" level="DEBUG"/>
    <logger name="net.snowflake.client.internal.jdbc.SnowflakeResultSetSerializableV1" level="DEBUG"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>